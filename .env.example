# =============================================================================
#  Ashfield Travel — Deploy Configuration
#  1. Copy this file:   cp .env.example .env
#  2. Fill in YOUR SiteGround details below
#  3. NEVER commit .env to Git (it's already in .gitignore)
# =============================================================================

# ── SiteGround SSH ────────────────────────────────────────────────────────────
# Find these in: SiteGround Site Tools → Devs → SSH Keys Manager

SG_USER=yourusername                          # e.g. ashfieldtravel
SG_HOST=your-server-ip-or-hostname            # e.g. uk123.siteground.eu
SG_PORT=18765                                 # SiteGround always uses 18765

# ── Paths on the server ───────────────────────────────────────────────────────
# The wp-content/themes/ directory on your SiteGround account

SG_THEMES_DIR=/home/yourusername/public_html/wp-content/themes
SG_THEME_PATH=/home/yourusername/public_html/wp-content/themes/ashfield-travel-theme

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO_SSH=git@github.com:sreekanthchn-sudo/ashfield-travel-theme.git
GIT_BRANCH=main
